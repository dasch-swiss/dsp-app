{
  "name": "dsp-app",
  "version": "13.10.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dasch-swiss/dsp-app.git"
  },
  "engines": {
    "node": "^22.13.0",
    "npm": "^10.9.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "nx run dsp-app:serve --tui false",
    "start-local": "nx run dsp-app:serve:development --host 0.0.0.0 --tui false",
    "start-local-with-observability": "docker compose -f docker-compose.observability.yml up -d && npm run start-local",
    "start-dev": "nx run dsp-app:serve:dev-server --tui false",
    "start-ls-test": "nx run dsp-app:serve:ls-test-server --tui false",
    "start-stage": "nx run dsp-app:serve:stage-server --tui false",
    "generate-openapi-module": "cd libs/vre/3rd-party-services/open-api && rm -rf src/lib/generated && npx openapi-generator-cli generate",
    "check-openapi-sync": "./scripts/check-openapi-sync.sh",
    "update-openapi": "curl -o libs/vre/3rd-party-services/open-api/dsp-api_spec.yaml https://api.dev.dasch.swiss/api/docs/docs.yaml && npm run generate-openapi-module",
    "e2e-local": "cd apps/dsp-app && npx cypress open --browser chrome --e2e",
    "e2e-ci-dev": "nx run dsp-app:e2e:development",
    "e2e-ci": "nx run dsp-app:e2e:production --browser chrome",
    "build": "nx run dsp-app:build",
    "build-prod": "nx run dsp-app:build:production",
    "test-ci-all": "nx run-many --all --target=test --configuration=ci",
    "test-local": "nx run dsp-app:test",
    "unit-test-coverage": "nx run-many --all --target=test --coverage && node tools/merge-coverage.js",
    "unit-test-coverage-ci": "nx run-many --all --target=test --configuration=ci --parallel=3 && node tools/merge-coverage.js",
    "lint-all": "nx run-many --all --target=lint",
    "lint-fix-all": "nx run-many --all --target=lint --fix",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org dasch --project javascript-angular ./dist/apps/dsp-app && sentry-cli sourcemaps upload --org dasch --project javascript-angular ./dist/apps/dsp-app",
    "storybook": "nx run dsp-app:storybook",
    "build-storybook": "nx run dsp-app:build-storybook",
    "test-storybook": "nx run dsp-app:test-storybook",
    "postinstall": "npm run generate-openapi-module && nx reset"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/cdk": "21.2.9",
    "@angular/common": "21.2.9",
