    "@ckeditor/ckeditor5-angular": "^5.2.0",
    "@grafana/faro-transport-otlp-http": "^2.3.1",
    "@grafana/faro-web-sdk": "^2.3.1",
    "@grafana/faro-web-tracing": "^2.3.1",
    "@ngrx/component-store": "^21.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@nx/angular": "23.0.1",
    "@sentry/angular": "^10.47.0",
    "angular-imask": "^7.5.0",
    "angular-split": "^20.0.0",
    "ckeditor5-custom-build": "github:dasch-swiss/ckeditor_custom_build#v2.1.5",
    "json2typescript": "^1.6.1",
    "jsonld": "^9.0.0",
    "jwt-decode": "^4.0.0",
    "ng2-pdf-viewer": "^10.4.0",
