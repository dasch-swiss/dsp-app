{
  "name": "vre-ui-ui",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/vre/ui/ui/src",
  "prefix": "dasch-swiss",
  "projectType": "library",
  "tags": ["type:ui"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/vre/ui/ui/jest.config.ts",
        "tsConfig": "libs/vre/ui/ui/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "tsc-errors": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project {projectRoot}/tsconfig.lib.json"
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/vre/ui/ui/.storybook",
        "browserTarget": "dsp-app:build",
        "compodoc": false,
        "styles": ["apps/dsp-app/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["apps/dsp-app/src/styles"]
        },
        "assets": [{ "glob": "**/*", "input": "apps/dsp-app/src/assets", "output": "assets" }]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/vre-ui-ui",
        "configDir": "libs/vre/ui/ui/.storybook",
        "browserTarget": "dsp-app:build",
        "compodoc": false,
        "styles": ["apps/dsp-app/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["apps/dsp-app/src/styles"]
        },
        "assets": [{ "glob": "**/*", "input": "apps/dsp-app/src/assets", "output": "assets" }]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/vre/ui/ui/.storybook --url=http://localhost:4400"
      },
      "configurations": {
        "ci": {
          "command": "test-storybook -c libs/vre/ui/ui/.storybook --url=http://localhost:6006"
        }
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "vre-ui-ui:build-storybook",
        "staticFilePath": "dist/storybook/vre-ui-ui",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "vre-ui-ui:build-storybook:ci"
        }
      }
    }
  }
}
